# The Gaffer — backend env. Copy to .env and fill in. NEVER commit real secrets.
# With ZERO of these set the system boots fully self-contained (in-memory log,
# scripted Gaffer, play-money custody, mock fixtures). Set keys to light up each
# real adapter independently. config.ts is the source of truth for every var.

# ── Server ──
PORT=8787
# Durable event-log path (SQLite). Unset → in-memory (state lost on restart).
# EVENT_LOG_PATH=./data/gaffer.sqlite

# ── The Gaffer's voice (Claude). Unset → deterministic ScriptedGaffer. ──
ANTHROPIC_API_KEY=
# Cheap model for frequent short reads; the marquee Verdict upgrades to Opus 4.8.
# GAFFER_MODEL=claude-haiku-4-5
# GAFFER_VERDICT_MODEL=claude-opus-4-8

# ── Walrus memory (MemWal). Unset → InMemoryMemoryStore. ──
# Get these from the `memwal login` browser flow.
MEMWAL_PRIVATE_KEY=
MEMWAL_ACCOUNT_ID=
# MEMWAL_SERVER_URL=
MEMWAL_NAMESPACE_PREFIX=gaffer

# ── On-chain / WAL custody (Sui). Both ADDRESS+KEY set → real SuiCustody. ──
# Dedicated Sessions wallet (hackathon requirement). Testnet now; rotate a fresh
# key for mainnet so its secret never lands in a transcript or commit.
SESSIONS_WALLET_ADDRESS=
SESSIONS_WALLET_KEY=
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
# WAL coin type on the target network (Coin<...::wal::WAL>). Verified on-chain per network.
# Testnet: 0x8270feb7375eee355e64fdb69c50abb6b5f9393a722883c1cf45f8e26048810a::wal::WAL
# Mainnet: 0x356a26eb9e012a68958082340d4c4116e7f55615cf27affcff209cf0ae544f59::wal::WAL  (re-verify before mainnet)
# Setting this (with the SESSIONS_WALLET_* vars) switches custody from play-money to real WAL.
# WAL_COIN_TYPE=

# ── Football data. Unset → MockMatchData (seeded fixtures). ──
API_FOOTBALL_KEY=
# API_FOOTBALL_BASE=https://v3.football.api-sports.io
# "league:season" pairs, comma-separated. World Cup is league 1, season 2026.
# FOOTBALL_COMPETITIONS=1:2026
# API_FOOTBALL_CACHE_TTL_MS=900000

# ── Auth / embedded wallets (Privy). appSecret set → real PrivyAuth, else DevAuth. ──
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_VERIFICATION_KEY=

# ── Game economy ──
# RAKE_BPS=250          # 2.5% of losers' pool → Manager's Pot
# MIN_PARTICIPANTS=3    # thin-pool threshold
# MIN_STAKE_FROST=10000000  # 0.01 WAL (1 WAL = 1e9 FROST)
